---
import { sekolah } from "../data/sekolah";
---

<div class="max-w-7xl mx-auto px-6 pt-6">

  <!-- HERO -->
  <section class="hero-card">
    <div class="px-6 py-8 md:px-10 md:py-10">

      <div class="hero-badge">Selamat Datang</div>

      <h1 class="hero-title">{sekolah.nama}</h1>
      <p class="hero-subtitle">{sekolah.slogan}</p>

      <div class="flex gap-3 flex-wrap mt-5">
        <a href="/profil" class="btn-primary">Tentang Kami</a>
        <a href="/kontak" class="btn-ghost">Hubungi Kami</a>
      </div>

    </div>
  </section>

  <!-- STATS -->
  <div class="stats-grid mt-4 mb-6">

    <div class="stat-card">
      <h3 class="stat-number">{sekolah.statistik.siswa}</h3>
      <p class="stat-label">Siswa</p>
    </div>

    <div class="stat-card">
      <h3 class="stat-number">{sekolah.statistik.guru}</h3>
      <p class="stat-label">Guru</p>
    </div>

    <div class="stat-card">
      <h3 class="stat-number">{sekolah.statistik.jurusan}</h3>
      <p class="stat-label">Jurusan</p>
    </div>

    <div class="stat-card">
      <h3 class="stat-number">{sekolah.statistik.prestasi}</h3>
      <p class="stat-label">Prestasi</p>
    </div>

  </div>

</div>

<style>
  .hero-card {
    border-radius: 1.25rem;
    overflow: hidden;
    background: linear-gradient(135deg, #0ea5e9, #0369a1) !important;
    border: 1px solid rgba(255,255,255,0.1);
    box-shadow: 0 4px 24px rgba(14, 165, 233, 0.25);
  }

  .dark .hero-card {
    background: linear-gradient(135deg, #0c4a6e, #0f172a);
  }

  .hero-badge {
    display: inline-block;
    font-size: 0.65rem;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: rgba(255,255,255,0.9);
    background: rgba(255,255,255,0.15);
    border: 1px solid rgba(255,255,255,0.2);
    border-radius: 999px;
    padding: 0.25rem 0.75rem;
    margin-bottom: 0.875rem;
  }

  .hero-title {
    font-size: clamp(1.5rem, 4vw, 2.5rem);
    font-weight: 800;
    color: #fff;
    line-height: 1.15;
    margin-bottom: 0.5rem;
  }

  .hero-subtitle {
    font-size: 0.95rem;
    color: rgba(255,255,255,0.75);
    line-height: 1.6;
    max-width: 480px;
  }

  .btn-primary {
    display: inline-flex;
    align-items: center;
    padding: 0.5rem 1.25rem;
    font-size: 0.8rem;
    font-weight: 600;
    color: #0369a1;
    background: #fff;
    border-radius: 0.625rem;
    text-decoration: none;
    transition: opacity 0.2s, transform 0.2s;
  }
  .btn-primary:hover { opacity: 0.9; transform: translateY(-1px); }

  .btn-ghost {
    display: inline-flex;
    align-items: center;
    padding: 0.5rem 1.25rem;
    font-size: 0.8rem;
    font-weight: 600;
    color: #fff;
    background: rgba(255,255,255,0.12);
    backdrop-filter: blur(8px);
    border: 1px solid rgba(255,255,255,0.25);
    border-radius: 0.625rem;
    text-decoration: none;
    transition: background 0.2s, transform 0.2s;
  }
  .btn-ghost:hover { background: rgba(255,255,255,0.2); transform: translateY(-1px); }

  .stats-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 0.75rem;
  }

  @media (min-width: 768px) {
    .stats-grid { grid-template-columns: repeat(4, 1fr); }
  }

  .stat-card {
    background: var(--bg-glass);
    backdrop-filter: var(--glass-blur);
    -webkit-backdrop-filter: var(--glass-blur);
    border: 1px solid var(--border-glass);
    border-radius: 1rem;
    padding: 1rem;
    text-align: center;
    box-shadow: var(--glass-shadow);
    transition: transform 0.2s, border-color 0.2s;
  }
  .stat-card:hover { transform: translateY(-2px); border-color: var(--border-color); }

  .stat-number {
    font-size: 1.75rem;
    font-weight: 800;
    color: var(--accent);
    line-height: 1;
    margin-bottom: 0.2rem;
  }

  .stat-label {
    font-size: 0.75rem;
    color: var(--text-muted);
    font-weight: 500;
  }
</style>