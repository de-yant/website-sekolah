---
import Layout from "../../../layouts/Layout.astro";
import { prestasiList } from "../../../data/prestasiList.js";
---

<Layout title="Prestasi Siswa">
  <section class="max-w-5xl mx-auto py-12 px-4">
    <div class="text-center mb-12">
      <h1 class="text-3xl font-bold mb-2">Prestasi Sekolah</h1>
      <p class="text-gray-500">Kebanggaan SMK 2 LPPM RI Majalaya</p>
    </div>

    <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
      {prestasiList.map((p) => (
        <a href={`/prestasi/${p.slug}`} class="bg-white p-6 rounded-2xl shadow-sm border border-gray-100 hover:shadow-lg transition">
          <div class="text-amber-500 font-bold text-sm mb-2 uppercase tracking-wider">{p.kategori}</div>
          <h3 class="font-bold text-xl mb-2">{p.judul}</h3>
          <p class="text-sm text-gray-600 italic">Siswa: {p.siswa}</p>
          <div class="mt-4 pt-4 border-t text-xs text-gray-400 font-bold">{p.tahun}</div>
        </a>
      ))}
    </div>
  </section>
</Layout>