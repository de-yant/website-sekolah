---
import Layout from "../../../layouts/Layout.astro";
import { prestasiList } from "../../../data/prestasiList.js";

export async function getStaticPaths() {
  return prestasiList.map((p) => ({
    params: { slug: p.slug },
    props: { prestasi: p },
  }));
}

const { prestasi } = Astro.props;
---

<Layout title={prestasi.judul}>
  <article class="max-w-3xl mx-auto py-16 px-4">
    <div class="mb-8">
      <span class="bg-amber-100 text-amber-700 px-3 py-1 rounded-full text-xs font-bold">{prestasi.kategori}</span>
      <h1 class="text-4xl font-extrabold mt-4 mb-2">{prestasi.judul}</h1>
      <p class="text-gray-600 text-lg">Peraih: <span class="font-semibold">{prestasi.siswa}</span></p>
    </div>
    
    <div class="bg-gray-50 p-8 rounded-2xl">
      <h4 class="font-bold mb-2">Tentang Prestasi</h4>
      <p class="text-gray-700 leading-relaxed">{prestasi.deskripsi}</p>
    </div>
    
    <a href="/prestasi" class="inline-block mt-8 text-blue-600 hover:underline">← Kembali ke Daftar Prestasi</a>
  </article>
</Layout>