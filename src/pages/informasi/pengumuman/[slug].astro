---
import Layout from "../../../layouts/Layout.astro";
import { pengumumanList } from "../../../data/pengumumanList.js";

export async function getStaticPaths() {
  return pengumumanList.map((p) => ({
    params: { slug: p.slug },
    props: { pengumuman: p },
  }));
}

const { pengumuman } = Astro.props;
---

<Layout title={pengumuman.judul}>
  <article class="max-w-2xl mx-auto py-10 px-4">
    <span class="text-sm text-gray-500">{pengumuman.tanggal}</span>
    <h1 class="text-3xl font-extrabold my-4">{pengumuman.judul}</h1>
    <div class="prose lg:prose-xl">
      {pengumuman.isi}
    </div>
    <a href="/pengumuman" class="inline-block mt-8 text-blue-600 hover:underline">← Kembali ke Pengumuman</a>
  </article>
</Layout>
