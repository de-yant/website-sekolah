---
import Layout from "../../../layouts/Layout.astro";
import { pengumumanList } from "../../../data/pengumumanList.js";
---

<Layout title="Pengumuman">
  <section class="p-8">
    <h1 class="text-2xl font-bold mb-6">Pengumuman Sekolah</h1>
    <div class="space-y-4">
      {pengumumanList.map((p) => (
        <a href={`/pengumuman/${p.slug}`} class="block p-5 bg-white border border-gray-200 rounded-xl hover:border-blue-500 transition">
          <div class="flex items-center gap-2 mb-2">
            {p.penting && <span class="bg-red-100 text-red-600 text-[10px] font-bold px-2 py-0.5 rounded">PENTING</span>}
            <span class="text-xs text-gray-400">{p.tanggal}</span>
          </div>
          <h2 class="font-semibold text-lg">{p.judul}</h2>
        </a>
      ))}
    </div>
  </section>
</Layout>