<script is:inline>
  const track = document.getElementById("slider-track");
  const dots = document.querySelectorAll(".dot");
  const total = dots.length;
  let current = 0;
  let timer;

  function goTo(n) {
    current = (n + total) % total;
    track.style.transform = `translateX(-${current * 100}%)`;
    dots.forEach((d, i) => d.classList.toggle("active", i === current));
  }

  function next() { goTo(current + 1); }
  function prev() { goTo(current - 1); }

  function startTimer() {
    clearInterval(timer);
    timer = setInterval(next, 5000);
  }

  document.getElementById("slider-next")?.addEventListener("click", () => { next(); startTimer(); });
  document.getElementById("slider-prev")?.addEventListener("click", () => { prev(); startTimer(); });
  dots.forEach((d) => d.addEventListener("click", () => { goTo(+d.dataset.index); startTimer(); }));

  startTimer();
</script>